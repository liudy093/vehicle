<launch>
<!-- Launch file for Livox Horizon LiDAR -->

	<arg name="rviz" default="false" />
	<arg name="config_file" default="$(find fast_lio2)/config/horizon.yaml" />
	<arg name="config_overlay_file" default="" />

	<rosparam command="load" file="$(arg config_file)" />
	<group if="$(eval arg('config_overlay_file') != '')">
		<rosparam command="load" file="$(arg config_overlay_file)" />
	</group>

	<param name="feature_extract_enable" type="bool" value="0"/>
	<param name="point_filter_num" type="int" value="3"/>
	<param name="max_iteration" type="int" value="3" />
	<param name="filter_size_surf" type="double" value="0.5" />
	<param name="filter_size_map" type="double" value="0.5" />
	<param name="cube_side_length" type="double" value="1000" />
	<param name="runtime_pos_log_enable" type="bool" value="0" />
    <node pkg="fast_lio2" type="fastlio_mapping" name="laserMapping" output="screen" /> 

	<group if="$(arg rviz)">
	<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_lio2)/rviz_cfg/loam_livox.rviz" />
	</group>
</launch>
